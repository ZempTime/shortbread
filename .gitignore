.DS_Store

# Local environment values. Commit examples, never populated variants.
.env
.env.*
!.env.example
!.env.*.example

# Rails runtime, local databases, credentials, and generated assets.
/.bundle
/config/*.key
/config/credentials*.yml.enc
/config/credentials/*.key
/log/*
!/log/.keep
/storage/*
!/storage/.keep
/tmp/*
!/tmp/.keep
!/tmp/pids/
/tmp/pids/*
!/tmp/pids/.keep
/public/assets
/public/vite*

# Browser and Go build/cache output.
/node_modules
*.tsbuildinfo
/cli/shortbread

# Local secret-tool and mise state.
/.fnox/
/.fnox.local.*
/fnox.local.*
/.mise.local.toml
/mise.local.toml
*.credentials.local
*.secrets.local
/credentials.local/
/secrets.local/
