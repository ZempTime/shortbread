# Copy this file outside Git or pass it with `docker compose --env-file`.
# Empty required values intentionally make Compose and bin/production fail closed.
RAILS_ENV=production
SHORTBREAD_APEX_HOST=
SHORTBREAD_POSTGRES_PASSWORD=
DATABASE_URL=
QUEUE_DATABASE_URL=
SHORTBREAD_BLOB_ROOT=/var/lib/shortbread/blobs
SECRET_KEY_BASE=
ANYCABLE_SECRET=
ANYCABLE_RPC_HOST=
ANYCABLE_HTTP_BROADCAST_URL=
ANYCABLE_WEBSOCKET_URL=

# Optional host-only port overrides for the production-shaped local rehearsal.
SHORTBREAD_WEB_PORT=13000
SHORTBREAD_CABLE_PORT=18080
