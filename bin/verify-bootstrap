#!/usr/bin/env bash
set -euo pipefail

bin/rails runner 'abort "unexpected Rails version" unless Rails.version == "8.1.3"; puts "Rails boot: #{Rails.version}"'
aube run build

(
  cd cli
  go test ./...
  go build -o ../tmp/shortbread-bootstrap ./cmd/shortbread
)

tmp/shortbread-bootstrap --help >/dev/null
echo "Bootstrap seams: green"
