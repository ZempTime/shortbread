#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/setup"

require_relative "../lib/shortbread/production_runtime"
require_relative "../lib/shortbread/worker_health"

begin
  command = ARGV.shift
  role = case command
  when "config"
    ARGV.shift || "web"
  when "health"
    ARGV.first
  when "migrate", "web", "worker", "cable"
    command
  end

  valid_arguments = command == "health" ? ARGV.one? : ARGV.empty?
  unless Shortbread::ProductionRuntime::PROCESS_ROLES.include?(role) && valid_arguments
    warn "usage: bin/production config [web|migrate|worker|cable]|migrate|web|worker|cable|health web|worker|cable"
    exit 64
  end

  ENV["SHORTBREAD_PROCESS_ROLE"] = role
  runtime = Shortbread::ProductionRuntime.new(role:)
  runtime.validate!

  case command
  when "config"
    require "json"
    puts JSON.pretty_generate(runtime.inventory)
  when "migrate"
    exec File.expand_path("rails", __dir__), "db:prepare"
  when "web"
    exec "bundle", "exec", "pitchfork", "-c", "config/pitchfork.rb"
  when "worker"
    Shortbread::WorkerHealth.mark_started!
    exec File.expand_path("jobs", __dir__)
  when "cable"
    exec "anycable-go", "--ignore-config-path"
  when "health"
    process = ARGV.shift

    case process
    when "web"
      require "net/http"
      request = Net::HTTP::Get.new("/health/ready")
      request["Host"] = ENV.fetch("SHORTBREAD_APEX_HOST")
      request["X-Forwarded-Proto"] = "https"
      response = Net::HTTP.start("127.0.0.1", Integer(ENV.fetch("PORT", 3000))) { |http| http.request(request) }
      abort "web readiness failed" unless response.is_a?(Net::HTTPSuccess)
    when "worker"
      require_relative "../config/environment"
      abort "worker health failed" unless Shortbread::WorkerHealth.healthy?
    when "cable"
      require "net/http"
      port = Integer(ENV.fetch("ANYCABLE_PORT", 8080))
      response = Net::HTTP.get_response("127.0.0.1", "/health", port)
      abort "cable health failed" unless response.is_a?(Net::HTTPSuccess)
    else
      warn "usage: bin/production health web|worker|cable"
      exit 64
    end
  else
    warn "usage: bin/production config [web|migrate|worker|cable]|migrate|web|worker|cable|health web|worker|cable"
    exit 64
  end
rescue Shortbread::ProductionRuntime::InvalidConfiguration => error
  warn "production configuration error: #{error.message}"
  exit 78
end
