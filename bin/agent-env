#!/usr/bin/env bash
set -euo pipefail

app_root=$(cd "$(dirname "$0")/.." && pwd)
checksum=$(printf '%s' "$app_root" | cksum)
checksum=${checksum%% *}
state_root=${SHORTBREAD_AGENT_STATE_DIR:-"/private/tmp/shortbread-agent-$checksum"}

rails_env=
if [[ "${1:-}" == "--rails-env" ]]; then
  rails_env=${2:-}
  [[ -n "$rails_env" ]] || {
    echo "usage: bin/agent-env [--rails-env ENV] -- command [args...]" >&2
    exit 2
  }
  shift 2
fi

if [[ "${1:-}" == "--" ]]; then
  shift
fi

[[ $# -gt 0 ]] || {
  echo "usage: bin/agent-env [--rails-env ENV] -- command [args...]" >&2
  exit 2
}

mkdir -p "$state_root"

export SHORTBREAD_POSTGRES_DATA_DIR=${SHORTBREAD_POSTGRES_DATA_DIR:-"$state_root/postgres/data"}
export SHORTBREAD_DATABASE_HOST=${SHORTBREAD_DATABASE_HOST:-"$state_root/postgres/socket"}
export SHORTBREAD_DATABASE_PORT=${SHORTBREAD_DATABASE_PORT:-$((20000 + checksum % 30000))}
export GOCACHE=${GOCACHE:-"$state_root/go-build"}
export RUBOCOP_CACHE_ROOT=${RUBOCOP_CACHE_ROOT:-"$state_root/rubocop-cache"}

if [[ -n "$rails_env" ]]; then
  export RAILS_ENV=$rails_env
fi

exec "$@"
